# 复制为 docker/.env 后使用；所有 change-me 值必须替换。
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=fastapiadmin
MYSQL_USER=fastapiadmin
MYSQL_PASSWORD=change-me-mysql
MYSQL_PORT=3306

REDIS_PASSWORD=change-me-redis
REDIS_PORT=6379

# 后端生产配置：SECRET_KEY 必须替换；ALLOW_ORIGINS 必须是 JSON 数组
SECRET_KEY=change-me-to-a-real-random-secret
ALLOW_ORIGINS=["https://your-frontend-domain.example.com"]
ALLOW_CREDENTIALS=True

BACKEND_PORT=8000
HTTP_PORT=80
HTTPS_PORT=443

PROJECT_NAME=fastapiadmin
DEPLOY_ENV=prod
